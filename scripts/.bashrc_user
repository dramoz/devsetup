#!/bin/bash
# ~/.bashrc_user
# Sourced from the distro's stock ~/.bashrc by a single guarded line:
#   [ -f "${HOME}/.bashrc_user" ] && . "${HOME}/.bashrc_user"
# This file deliberately does NOT replace /etc/bashrc or /etc/bash.bashrc —
# the distro keeps ownership of system-wide setup; we only layer extras on top.

# --------------------------------------------------------------------------
# History
HISTCONTROL=ignoreboth
HISTSIZE=100000
HISTFILESIZE=200000
shopt -s histappend
shopt -s checkwinsize

# Echo helpers (used by some helper scripts)
L1='==============================================================================='
L2='------------------------------------------------------------'

# --------------------------------------------------------------------------
# Devsetup paths and PATH
export DEVSETUP_DIR="${HOME}/dev/devsetup"
export PROJECTS_SCRIPTS="${HOME}/scripts/projects"
[[ -d "${PROJECTS_SCRIPTS}" ]] || mkdir -p "${PROJECTS_SCRIPTS}"

__path_prepend() {
    case ":${PATH}:" in
        *":$1:"*) ;;
        *) PATH="$1:${PATH}" ;;
    esac
}
__path_prepend "${HOME}/tools"
__path_prepend "${HOME}/.local/bin"
__path_prepend "${PROJECTS_SCRIPTS}"
export PATH
unset -f __path_prepend

# --------------------------------------------------------------------------
# virtualenvwrapper (installed via distro package — see linux_setup.sh)
# Fedora:  /usr/bin/virtualenvwrapper.sh                (python3-virtualenvwrapper)
# Ubuntu:  /usr/share/virtualenvwrapper/virtualenvwrapper.sh  (virtualenvwrapper)
# Fallback: pipx / pip --user install in ~/.local/bin
export WORKON_HOME="${HOME}/.virtualenvs"
export VIRTUALENVWRAPPER_PYTHON="$(command -v python3)"
for _vew in /usr/bin/virtualenvwrapper.sh \
            /usr/share/virtualenvwrapper/virtualenvwrapper.sh \
            "${HOME}/.local/bin/virtualenvwrapper.sh"; do
    if [[ -r "${_vew}" ]]; then
        # shellcheck disable=SC1090
        source "${_vew}"
        break
    fi
done
unset _vew

# --------------------------------------------------------------------------
# Project helper — generate a per-project activation script.
# Old version had a broken heredoc that ran the env-mutating commands in the
# current shell instead of writing them into the generated file.
create_project() {
    local name="$1"
    local prj_sh prj_path
    if [[ -z "${name}" ]]; then
        echo "usage: create_project <name>" >&2
        return 1
    fi
    prj_sh="${PROJECTS_SCRIPTS}/${name}.sh"
    prj_path="$(pwd)"
    if [[ -f "${prj_sh}" ]]; then
        echo "create_project: ${prj_sh} already exists" >&2
        return 1
    fi
    cat > "${prj_sh}" <<EOF
#!/bin/bash
# Auto-generated by create_project on $(date +%F)
export PRJ="${prj_path}"
cd "\${PRJ}" || return
workon hdl 2>/dev/null || true
EOF
    chmod +x "${prj_sh}"
    echo "Created ${prj_sh} — activate with: source ${name}.sh"
}

# --------------------------------------------------------------------------
# Prompt
# Fast git branch + dirty check — uses git plumbing instead of full `git status`,
# which was the dominant per-prompt cost in the old .bashrc_devsetup.
__git_branch_dirty() {
    local branch
    branch=$(git symbolic-ref --short HEAD 2>/dev/null) || return
    if ! git diff --quiet 2>/dev/null || ! git diff --cached --quiet 2>/dev/null; then
        printf '%s*' "${branch}"
    else
        printf '%s' "${branch}"
    fi
}

__setprompt() {
    local last=$?
    local RED='\[\033[0;31m\]'
    local LRED='\[\033[1;31m\]'
    local GREEN='\[\033[0;32m\]'
    local LGREEN='\[\033[1;32m\]'
    local BROWN='\[\033[0;33m\]'
    local WHITE='\[\033[1;37m\]'
    local NC='\[\033[0m\]'

    PS1='\n'
    if (( last != 0 )); then
        PS1+="${RED}<exit:${last}>${NC} "
    fi

    local gb
    gb=$(__git_branch_dirty)
    [[ -n "${gb}" ]] && PS1+="${LGREEN}[git:${gb}]${NC} "

    [[ -n "${VIRTUAL_ENV:-}" ]] && PS1+="${WHITE}($(basename "${VIRTUAL_ENV}"))${NC} "

    PS1+="${GREEN}\h${NC}:${BROWN}\w${NC}/\n"
    if (( EUID == 0 )); then
        PS1+="${LRED}#${NC} "
    else
        PS1+="${GREEN}\$${NC} "
    fi

    PS2="${WHITE}>${NC} "
}

# Install __setprompt without clobbering whatever the distro already set.
# Fedora's /etc/bashrc uses an array PROMPT_COMMAND (terminal-title hook);
# Ubuntu uses a scalar. ${var@a} returns attribute flags on bash 5+.
if [[ ${PROMPT_COMMAND@a} == *a* ]]; then
    PROMPT_COMMAND+=(__setprompt)
else
    PROMPT_COMMAND="__setprompt${PROMPT_COMMAND:+;${PROMPT_COMMAND}}"
fi

# --------------------------------------------------------------------------
# Common aliases
if [[ -f "${HOME}/.bash_aliases" ]]; then
    # shellcheck disable=SC1090
    source "${HOME}/.bash_aliases"
fi

# --------------------------------------------------------------------------
# Local, machine-specific overrides (env vars, license paths, tool paths, ...)
if [[ -f "${HOME}/.bashrc_local" ]]; then
    # shellcheck disable=SC1090
    source "${HOME}/.bashrc_local"
fi
